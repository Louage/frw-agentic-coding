{
  "name": "frw-agentic-coding",
  "displayName": "The Framework Agentic Coding",
  "description": "Internal company extension that provides AI agent skills (executable tools + knowledge) and rules (custom instructions) for Business Central (AL) development in VS Code chat/agent mode.",
  "version": "0.2.0",
  "publisher": "theframework",
  "private": true,
  "license": "UNLICENSED",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Louage/frw-agentic-coding.git"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "languageModelTools": [
      {
        "name": "frw_get_coding_standard",
        "displayName": "Get The Framework Coding Standard",
        "modelDescription": "Returns the official AL / Business Central coding standard from The Framework for a given topic. Available topics: code-style, naming-conventions, performance, error-handling, events, testing, upgrade, guidelines-rules. Use this tool whenever the user asks how something should be done according to company standards, or before generating or reviewing AL code that must follow company conventions. Returns the full Markdown rule file. If the requested topic is unknown, the tool returns the list of available topics.",
        "toolReferenceName": "frwCodingStandard",
        "canBeReferencedInPrompt": true,
        "icon": "$(book)",
        "userDescription": "Look up an AL / Business Central coding standard from The Framework by topic.",
        "tags": [
          "frw",
          "standards",
          "al",
          "business-central"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "topic": {
              "type": "string",
              "description": "The coding standard topic to look up, e.g. 'naming-conventions', 'code-style', 'performance', 'error-handling', 'events', 'testing', 'upgrade', or 'guidelines-rules'."
            }
          },
          "required": [
            "topic"
          ]
        }
      }
    ],
    "chatSkills": [
      {
        "path": "./assets/skills/add-base-bc-code/SKILL.md"
      },
      {
        "path": "./assets/skills/create-feature-spec/SKILL.md"
      },
      {
        "path": "./assets/skills/create-tech-design/SKILL.md"
      },
      {
        "path": "./assets/skills/finalise-feature/SKILL.md"
      },
      {
        "path": "./assets/skills/generate-docs/SKILL.md"
      },
      {
        "path": "./assets/skills/run-al-tests/SKILL.md"
      },
      {
        "path": "./assets/skills/setup-al-vibe-rules/SKILL.md"
      }
    ],
    "chatInstructions": [
      {
        "path": "./assets/instructions/al-code-style.instructions.md"
      },
      {
        "path": "./assets/instructions/al-naming-conventions.instructions.md"
      },
      {
        "path": "./assets/instructions/al-guidelines-rules.instructions.md"
      },
      {
        "path": "./assets/instructions/al-performance.instructions.md"
      },
      {
        "path": "./assets/instructions/al-error-handling.instructions.md"
      },
      {
        "path": "./assets/instructions/al-events.instructions.md"
      },
      {
        "path": "./assets/instructions/al-testing.instructions.md"
      },
      {
        "path": "./assets/instructions/al-upgrade.instructions.md"
      }
    ],
    "commands": [
      {
        "command": "frwAgenticCoding.checkForUpdates",
        "title": "The Framework: Check for extension updates",
        "category": "The Framework"
      },
      {
        "command": "frwAgenticCoding.refreshSkills",
        "title": "Refresh",
        "category": "The Framework",
        "icon": "$(refresh)"
      },
      {
        "command": "frwAgenticCoding.refreshRules",
        "title": "Refresh",
        "category": "The Framework",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "frwAgenticCoding",
          "title": "The Framework",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "frwAgenticCoding": [
        {
          "id": "frwSkills",
          "name": "Skills",
          "icon": "$(rocket)",
          "contextualTitle": "The Framework"
        },
        {
          "id": "frwRules",
          "name": "Rules",
          "icon": "$(law)",
          "contextualTitle": "The Framework"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "frwAgenticCoding.refreshSkills",
          "when": "view == frwSkills",
          "group": "navigation"
        },
        {
          "command": "frwAgenticCoding.refreshRules",
          "when": "view == frwRules",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "The Framework Agentic Coding",
      "properties": {
        "frwAgenticCoding.update.repository": {
          "type": "string",
          "default": "Louage/frw-agentic-coding",
          "markdownDescription": "The private GitHub repository (in `owner/repo` form) that publishes new `.vsix` releases of this extension. Used by the in-editor update check."
        },
        "frwAgenticCoding.update.checkOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Check the configured GitHub repository for a newer release when VS Code starts."
        },
        "frwAgenticCoding.update.includePrereleases": {
          "type": "boolean",
          "default": false,
          "description": "Also consider GitHub pre-releases when checking for updates."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "lint": "eslint src",
    "vsix": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.13.0",
    "typescript": "^5.6.0"
  }
}
