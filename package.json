        {
          "command": "frwAgenticCoding.refreshAgents",
          "when": "view == frwAgents",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "The Framework Agentic Coding",
      "properties": {
        "frwAgenticCoding.update.repository": {
          "type": "string",
          "default": "Louage/frw-agentic-coding",
          "markdownDescription": "The private GitHub repository (in `owner/repo` form) that publishes new `.vsix` releases of this extension. Used by the in-editor update check."
        },
        "frwAgenticCoding.update.checkOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Check the configured GitHub repository for a newer release when VS Code starts."
        },
        "frwAgenticCoding.update.includePrereleases": {
          "type": "boolean",
          "default": false,
          "description": "Also consider GitHub pre-releases when checking for updates."
        },
        "frwAgenticCoding.sources.catalogPath": {
          "type": "string",
          "default": "automation/sources/catalog.json",
          "description": "Workspace-relative path to the external source catalog used by the asset sync pipeline."
        },
        "frwAgenticCoding.sources.multiRoot.requireSelection": {
          "type": "boolean",
          "default": true,
          "description": "When true, repository-scoped actions in multi-root workspaces require explicit human repository selection when no target is given."
        }
      }
    },
