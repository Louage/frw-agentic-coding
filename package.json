  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "lint": "eslint src",
    "vsix": "vsce package --no-dependencies",
    "sync:sources": "pwsh -File automation/scripts/Sync-ExternalSources.ps1 -Clean",
    "validate:source-contract": "pwsh -File automation/scripts/Validate-SourceContractsFromCatalog.ps1",
    "validate:source-contract:strict": "pwsh -File automation/scripts/Validate-SourceContractsFromCatalog.ps1 -RequireAtLeastOneContract",
    "sync:mcp-sources": "pwsh -File automation/scripts/Sync-McpKnowledgeSources.ps1 -Clean",
    "validate:mcp-schemas": "pwsh -File automation/scripts/Validate-McpSourcesSchemas.ps1",
    "validate:contribution-paths": "node automation/scripts/Validate-ContributionPaths.mjs",
    "generate:contributions": "pwsh -File automation/scripts/Generate-ContributionManifest.ps1",
    "apply:contributions": "pwsh -File automation/scripts/Apply-ContributionManifest.ps1",
    "pipeline:assets": "npm run sync:sources && npm run generate:contributions && npm run apply:contributions",
    "pipeline:mcp": "npm run sync:mcp-sources"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.2.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.13.0",
    "typescript": "^5.6.0"
  }
}
