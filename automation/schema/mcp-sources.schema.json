{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theframework.internal/schemas/mcp-sources.schema.json",
  "title": "FRW MCP Sources Config v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "sources"
  ],
  "properties": {
    "contractVersion": {
      "type": "string",
      "const": "1.0"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "enabled",
          "owner",
          "repo",
          "branch",
          "kind",
          "usage"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
          },
          "enabled": {
            "type": "boolean"
          },
          "owner": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "repo": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "branch": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "kind": {
            "type": "string",
            "const": "mcp-knowledge"
          },
          "usage": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        }
      }
    }
  }
}
